{
  "typecheck": "auto",
  "test": "npm test --silent",
  "build": "npm run build",
  "envGuard": {
    "enabled": true,
    "minKeys": 20,
    "minBytes": 500,
    "globs": [
      ".env.production"
    ]
  },
  "migrationRule": "drizzle-kit migrate only \u2014 drizzle-kit push is FORBIDDEN on prod"
}
