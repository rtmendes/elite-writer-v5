# Elite Writer V5 — Production Environment Variables
# Copy to .env.production and fill in values

# ─── Core ──────────────────────────────────────────
NODE_ENV=production
PORT=3000
APP_URL=https://elitewriter.insightprofit.live

# ─── Database (MySQL) ─────────────────────────────
DATABASE_URL=mysql://elite_writer:YOUR_DB_PASSWORD@thepopebot-mysql:3306/elite_writer

# ─── Auth ──────────────────────────────────────────
JWT_SECRET=CHANGE_ME_RANDOM_64_CHARS
ADMIN_EMAIL=admin@elitewriter.app
ADMIN_PASSWORD_HASH=GENERATE_WITH_POST_/api/auth/hash

# ─── AI APIs ──────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
PERPLEXITY_API_KEY=
GEMINI_API_KEY=

# ─── News APIs ────────────────────────────────────
NEWSAPI_KEY=
MEDIASTACK_KEY=
GNEWS_KEY=

# ─── Image/Video Generation ──────────────────────
STABILITY_AI_KEY=
RUNWARE_API_KEY=
FAL_AI_API_KEY=
PIAPI_KEY=

# ─── Google OAuth ─────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
YOUTUBE_API_KEY=

# ─── Supabase (legacy/KB) ────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Affine (optional) ───────────────────────────
AFFINE_API_KEY=
AFFINE_WORKSPACE_URL=
