# Elite Writer V5 — Production Environment Variables
# Copy to .env.production and fill in values

# ─── Core ──────────────────────────────────────────
NODE_ENV=production
PORT=3000
APP_URL=https://elitewriter.insightprofit.live

# ─── Database (MySQL) ─────────────────────────────
DATABASE_URL=mysql://elite_writer:YOUR_DB_PASSWORD@thepopebot-mysql:3306/elite_writer

# ─── Auth ──────────────────────────────────────────
JWT_SECRET=CHANGE_ME_RANDOM_64_CHARS
ADMIN_EMAIL=admin@elitewriter.app
ADMIN_PASSWORD_HASH=GENERATE_WITH_POST_/api/auth/hash

# ─── AI APIs ──────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
PERPLEXITY_API_KEY=
GEMINI_API_KEY=

# ─── News APIs ────────────────────────────────────
NEWSAPI_KEY=
MEDIASTACK_KEY=
GNEWS_KEY=
PERIGON_API_KEY=

# ─── Image/Video Generation ──────────────────────
STABILITY_AI_KEY=
RUNWARE_API_KEY=
FAL_AI_API_KEY=
PIAPI_KEY=

# ─── Google OAuth ─────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
YOUTUBE_API_KEY=

# ─── Supabase (legacy/KB) ────────────────────────
# Server-side only (NOT exposed to the browser). service_role bypasses RLS —
# it must NEVER be copied into a VITE_ var.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Supabase Realtime (Slice 4 — live collab + presence) ──────────
# Browser-exposed (Vite only ships VITE_-prefixed vars to the client bundle).
# Use the *anon public* key from Supabase Studio → Settings → API.
# DO NOT paste the service_role key here — that would ship admin DB access to
# every visitor's browser. Leave both blank to keep realtime OFF (graceful).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─── Affine (optional) ───────────────────────────
AFFINE_API_KEY=
AFFINE_WORKSPACE_URL=

# ─── Analytics (optional) ───────────────────────────
# When both values are present, the client injects the analytics script at runtime.
# Leave both empty to disable analytics without leaking unresolved Vite tokens in HTML.
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# ─── ZimmWriter ingest (dual auth — HMAC and/or token) ─
# Generate each: openssl rand -hex 32
ZIMMWRITER_INGEST_SECRET=
ZIMMWRITER_INGEST_TOKEN=
