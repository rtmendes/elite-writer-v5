# Elite Writer V5 — Local / ingest environment variables
# Copy to .env and fill values (Infisical: insightprofit project, prod path /)

DATABASE_URL=postgresql://user:pass@127.0.0.1:5432/elite_writer
JWT_SECRET=dev-insecure-jwt-secret
ADMIN_EMAIL=admin@elitewriter.app

# ZimmWriter webhook ingest (dual auth — either method authorizes)
# Generate: openssl rand -hex 32
ZIMMWRITER_INGEST_SECRET=
ZIMMWRITER_INGEST_TOKEN=
